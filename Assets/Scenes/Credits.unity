--- !u!114 &557248700
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 557248698}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Nueve infiernos de tormento estructurado.\nNueve c\xEDrculos donde el
    pecado y la desesperaci\xF3n\nfueron tallados en fr\xEDos bloques de fuego y
    brea.\n\nEl peregrino descendi\xF3 m\xE1s all\xE1 de donde la luz del Creador
    alcanza,\ncaminando a trav\xE9s del abismo que los hombres construyeron\ncuando
    decidieron darle la espalda al Cielo.\n\nHa pisado el fango de los condenados.\nHa
    purgado la oscuridad en cada casilla del destino.\nNi la furia del Demonio de
    Brea,\nni los lamentos de los Herejes olvidados por la mano de Dios,\npudieron
    quebrar su voluntad de hierro.\n\nDonde el Alt\xEDsimo apart\xF3 su sagrada mirada,\nel
    peregrino se convirti\xF3 en el portador de la llama de la redenci\xF3n.\nEl
    juicio ha sido dictado y la penitencia, pagada.\n\nAhora, los muros del infierno
    se derrumban.\nLa geometr\xEDa del castigo cede ante la Gracia de una fe inquebrantable.\nLa
    g\xE1rgola vuelve a ser piedra inerte y el abismo guarda silencio.\n\nEl peregrino
    alza la vista.\nM\xE1s all\xE1 del oscuro techo de su prisi\xF3n c\xFAbica,\nuna
    luz pura, dorada e infinita se abre paso.\nEs el dise\xF1o original. Es la voluntad
    del Gran Arquitecto del Universo.\n\nEl descenso ha terminado.\nY as\xED, salimos
    a ver de nuevo las estrellas...\nLa ascensi\xF3n hacia Su gloria eterna acaba
    de comenzar."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
